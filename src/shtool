    weather = _get_weather()
    print(f"  Current weather: {weather}")
    try:
        mood_score = _prompt_scale("How is your overall mood?")
        energy_score = _prompt_scale("How is your energy level?")
        focus_score = _prompt_scale("How focused do you feel?")
        mood_label = input("Describe your mood in a word (e.g. productive, anxious, calm): ").strip()
        factors = input("What factors are affecting you? (e.g. sleep, stress, exercise): ").strip()
