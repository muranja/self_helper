def run_command(cmd: List[str]) -> None:
    """Helper to run system commands and preserve colors/formatting."""
    try:
        subprocess.run(cmd, check=True)
    except subprocess.CalledProcessError as e:
        sys.exit(e.returncode)
    except FileNotFoundError:
        print(f"\033[1;31mError:\033[0m Executable not found for: {' '.join(cmd)}")
        sys.exit(1)

def export_database_dump() -> None:
    """Extracts goals, tracking history, app usage, and web domains visited into a unified JSON structure based on privacy configuration."""
    import socket
    import urllib.request
    
    # 1. Fetch Goals and tracked limits from SQLite
    if not DB_PATH.exists():
        print(f"\033[1;31mError:\033[0m Goals database not found at {DB_PATH}.")
        sys.exit(1)

    goals = []
    usage = []
    privacy_level = "low"
    try:
        conn = sqlite3.connect(DB_PATH)
        conn.row_factory = sqlite3.Row
        init_settings(conn)
        privacy_level = get_setting(conn, "privacy_level", "low")
        
        goals_cursor = conn.execute("SELECT app_pattern, target_seconds, is_limit, created_at FROM goals")
        goals = [dict(row) for row in goals_cursor.fetchall()]
        for g in goals:
            g["target_hours"] = round(g["target_seconds"] / 3600.0, 2)
            g["is_limit"] = bool(g["is_limit"])

        usage_cursor = conn.execute("SELECT date, app_pattern, duration_seconds FROM daily_accumulated_time ORDER BY date DESC, duration_seconds DESC")
        usage = [dict(row) for row in usage_cursor.fetchall()]
        for u in usage:
            u["duration_hours"] = round(u["duration_seconds"] / 3600.0, 3)

        conn.close()
    except Exception as e:
        print(f"\033[1;31mWarning:\033[0m Could not query local goals database: {e}")

    # 2. Query raw ActivityWatch telemetry buckets for overall app and domain breakdowns
    buckets = {}
    if privacy_level != "high":
        hostname = socket.gethostname()
        try:
            req = urllib.request.Request("http://127.0.0.1:5600/api/0/buckets", headers={"User-Agent": "SelfHelper/1.0"})
            with urllib.request.urlopen(req, timeout=2.0) as response:
                buckets = json.loads(response.read().decode("utf-8"))
        except Exception as e:
            print(f"\033[1;33mWarning:\033[0m Could not reach ActivityWatch server: {e}")

    window_bucket = next((b for b in buckets if "aw-watcher-window" in b and hostname in b), None) if buckets else None
    web_bucket = next((b for b in buckets if "aw-watcher-web" in b and hostname in b), None) if buckets else None

    # 3. Aggregate active applications logged today
    app_durations = {}
    if window_bucket and privacy_level != "high":
        try:
            req = urllib.request.Request(
                f"http://127.0.0.1:5600/api/0/buckets/{window_bucket}/events?limit=2000",
                headers={"User-Agent": "SelfHelper/1.0"}
            )
            with urllib.request.urlopen(req, timeout=2.0) as response:
                events = json.loads(response.read().decode("utf-8"))
            
            today_str = datetime.now().strftime("%Y-%m-%d")
            for event in events:
                timestamp_str = event.get("timestamp", "")
                if timestamp_str and timestamp_str.split("T")[0] == today_str:
                    data = event.get("data", {})
                    app = data.get("app", "Unknown")
                    if app != "Unknown":
                        app_durations[app] = app_durations.get(app, 0.0) + event.get("duration", 0.0)
        except Exception as e:
            print(f"\033[1;33mWarning:\033[0m Could not parse application window events: {e}")

    # 4. Aggregate browser domains and exact URLs visited today
    domain_durations = {}
    url_durations = {}
    if web_bucket and privacy_level != "high":
        try:
            req = urllib.request.Request(
                f"http://127.0.0.1:5600/api/0/buckets/{web_bucket}/events?limit=2000",
                headers={"User-Agent": "SelfHelper/1.0"}
            )
            with urllib.request.urlopen(req, timeout=2.0) as response:
                events = json.loads(response.read().decode("utf-8"))
            
            today_str = datetime.now().strftime("%Y-%m-%d")
            for event in events:
                timestamp_str = event.get("timestamp", "")
                if timestamp_str and timestamp_str.split("T")[0] == today_str:
                    data = event.get("data", {})
                    url = data.get("url", "")
                    title = data.get("title", "")
                    duration = event.get("duration", 0.0)
                    
                    if url and duration > 0:
                        # Domain aggregation
                        from urllib.parse import urlparse
                        domain = urlparse(url).netloc
                        if domain.startswith("www."):
                            domain = domain[4:]
                        if domain:
                            domain_durations[domain] = domain_durations.get(domain, 0.0) + duration
                        
                        # URL aggregation (ONLY IN LOW PRIVACY)
                        if privacy_level == "low":
                            url_durations[url] = url_durations.get(url, {"duration": 0.0, "title": title})
                            url_durations[url]["duration"] += duration
        except Exception as e:
            print(f"\033[1;33mWarning:\033[0m Could not parse browser tab events: {e}")

    sorted_apps = sorted(app_durations.items(), key=lambda x: x[1], reverse=True)
    sorted_domains = sorted(domain_durations.items(), key=lambda x: x[1], reverse=True)
    sorted_urls = sorted(url_durations.items(), key=lambda x: x[1]["duration"], reverse=True)

    # 5. Build export payload
    payload = {
        "dump_timestamp": datetime.now(timezone.utc).isoformat(),
        "schema_version": "1.2",
        "privacy_level": privacy_level,
        "goals": goals,
        "historical_goal_usage": usage,
        "daily_app_usage": [{"app": app, "seconds": round(sec, 1), "hours": round(sec/3600.0, 3)} for app, sec in sorted_apps],
        "daily_web_domain_usage": [{"domain": dom, "seconds": round(sec, 1), "hours": round(sec/3600.0, 3)} for dom, sec in sorted_domains],
        "daily_web_url_usage": [
            {
                "url": url,
                "title": info["title"],
                "seconds": round(info["duration"], 1),
                "hours": round(info["duration"]/3600.0, 3)
            }
            for url, info in sorted_urls
        ]
    }

    # 6. Format clean human-readable console output
    print("\033[1;32m=== HISTORICAL USAGE DATABASE DUMP ===\033[0m")
    print(f"Dump Timestamp: {payload['dump_timestamp']}")
    print(f"Active Privacy Level: \033[1;36m{privacy_level.upper()}\033[0m\n")
    
    print("\033[1;33m[1] Configured Goals:\033[0m")
    for g in goals:
        type_str = "LIMIT" if g["is_limit"] else "TARGET"
        print(f"  • '{g['app_pattern']}' ({type_str}) target: {g['target_hours']}h")

    print("\n\033[1;33m[2] Daily Log Entries (Goal Matching):\033[0m")
    if not usage:
        print("  No usage records logged yet.")
    else:
        for u in usage:
            print(f"  • [{u['date']}] '{u['app_pattern']}': {u['duration_hours']:.3f}h ({int(u['duration_seconds'] // 60)}m)")

    if privacy_level != "high":
        print("\n\033[1;33m[3] Detailed Website Domain Usage Today (Firefox Extension):\033[0m")
        if not sorted_domains:
            print("  No website domains logged today.")
        else:
            for dom, sec in sorted_domains[:15]:
                print(f"  • '{dom}': {sec/3600.0:.3f}h ({int(sec // 60)}m {int(sec % 60)}s)")

        print("\n\033[1;33m[4] Detailed Application Window Usage Today:\033[0m")
        if not sorted_apps:
            print("  No active application windows logged today.")
        else:
            for app, sec in sorted_apps[:15]:
                print(f"  • '{app}': {sec/3600.0:.3f}h ({int(sec // 60)}m {int(sec % 60)}s)")

    if privacy_level == "low":
        print("\n\033[1;33m[5] Detailed Website URL Usage Today:\033[0m")
        if not sorted_urls:
            print("  No website URLs logged today.")
        else:
            for url, info in sorted_urls[:15]:
                sec = info["duration"]
                title = info["title"][:50] + "..." if len(info["title"]) > 50 else info["title"]
                print(f"  • '{title}'\n    URL: {url}\n    Time: {sec/3600.0:.3f}h ({int(sec // 60)}m {int(sec % 60)}s)")

    # Save to output file
    out_path = Path.home() / "self_helper_dump.json"
    with open(out_path, "w") as f:
        json.dump(payload, f, indent=2)

    print(f"\n\033[1;32m✓ JSON payload written to: {out_path}\033[0m")
    print("You can provide this JSON file to third-party tools or AI engines for analysis.")

def main() -> None:
    if len(sys.argv) < 2:
        print_help_menu()
        sys.exit(0)

    cmd = sys.argv[1]
    args = sys.argv[2:]

    # Parse and route subcommands
    if cmd in ("--help", "-h", "help"):
        print_help_menu()
    elif cmd == "config":
        if not DB_PATH.exists():
            DB_PATH.parent.mkdir(parents=True, exist_ok=True)
        conn = sqlite3.connect(DB_PATH)
        conn.row_factory = sqlite3.Row
        init_settings(conn)
        
        if len(args) == 0:
            privacy = get_setting(conn, "privacy_level", "low")
            audio = get_setting(conn, "audio_alerts", "on")
            speech = get_setting(conn, "speech_alerts", "off")
            print(f"\033[1;36m=== SHTOOL CONFIGURATION ===\033[0m")
            print(f"Privacy Level: \033[1;32m{privacy.upper()}\033[0m")
            print(f"Audio Alerts (chimes): \033[1;32m{audio.upper()}\033[0m")
            print(f"Speech Alerts (TTS):   \033[1;32m{speech.upper()}\033[0m")
            print("\nConfigure via:")
            print("  \033[1;33mshtool config --privacy [low|medium|high]\033[0m")
            print("  \033[1;33mshtool config --audio [on|off]\033[0m")
            print("  \033[1;33mshtool config --speech [on|off]\033[0m")
        elif len(args) == 2 and args[0] == "--privacy":
            level = args[1].lower()
            if level in ("low", "medium", "high"):
                set_setting(conn, "privacy_level", level)
                print(f"✓ Privacy level updated to: \033[1;32m{level.upper()}\033[0m")
            else:
                print("\033[1;31mError:\033[0m Privacy level must be 'low', 'medium', or 'high'.")
        elif len(args) == 2 and args[0] == "--audio":
            val = args[1].lower()
            if val in ("on", "off"):
                set_setting(conn, "audio_alerts", val)
                print(f"✓ Audio alerts updated to: \033[1;32m{val.upper()}\033[0m")
            else:
                print("\033[1;31mError:\033[0m Audio alerts value must be 'on' or 'off'.")
        elif len(args) == 2 and args[0] == "--speech":
            val = args[1].lower()
            if val in ("on", "off"):
                set_setting(conn, "speech_alerts", val)
                print(f"✓ Speech alerts updated to: \033[1;32m{val.upper()}\033[0m")
            else:
                print("\033[1;31mError:\033[0m Speech alerts value must be 'on' or 'off'.")
        else:
            print("\033[1;31mUsage:\033[0m")
            print("  shtool config")
            print("  shtool config --privacy [low|medium|high]")
            print("  shtool config --audio [on|off]")
            print("  shtool config --speech [on|off]")
        conn.close()
    elif cmd == "status":
        run_command(["/home/vin/.local/bin/self_helper.py", "status"])
    elif cmd == "report":
        run_command(["/home/vin/.local/bin/self_help_report.py"])
    elif cmd == "weekly":
        run_command(["/home/vin/.local/bin/self_help_report.py", "--weekly"])
    elif cmd == "goals":
        run_command(["/home/vin/.local/bin/self_helper.py", "list-goals"])
    elif cmd == "add":
        run_command(["/home/vin/.local/bin/self_helper.py", "add-goal"] + args)
    elif cmd == "daemon":
        run_command(["systemctl", "--user", "status", "self-helper.service"])
    elif cmd == "restart":
        run_command(["systemctl", "--user", "restart", "self-helper.service"])
    elif cmd == "dump":
        export_database_dump()
    else:
        print(f"\033[1;31mUnknown command:\033[0m {cmd}")
        print("Type 'shtool --help' to see list of valid commands.")
        sys.exit(1)

if __name__ == "__main__":
    main()
