    except (KeyboardInterrupt, EOFError):
        print("\nCancelled."); conn.close(); return

    conn.execute(
        "INSERT INTO mood_journal (timestamp, mood_score, energy_score, focus_score, mood_label, factors, gratitude, notes, weather_info) "
        "VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?);",
        (datetime.now(timezone.utc).isoformat(), mood_score, energy_score, focus_score, mood_label, factors, gratitude, notes, weather))
