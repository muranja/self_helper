def interactive_remove(args: List[str]) -> None:
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    init_settings(conn)
    
    # Fetch existing goals
    cursor = conn.execute("SELECT app_pattern, target_seconds, is_limit FROM goals;")
    goals = cursor.fetchall()
    
    if not goals:
        print("\033[1;33mNo goals are currently configured.\033[0m")
        conn.close()
        return
        
    pattern = args[0] if args else None
    
    if not pattern:
        print("\033[1;36m=== REMOVE GOAL (INTERACTIVE) ===\033[0m")
        for i, g in enumerate(goals, 1):
            g_type = "LIMIT" if g["is_limit"] else "TARGET"
            hours = round(g["target_seconds"] / 3600.0, 2)
            print(f"  [{i}] {g['app_pattern']} ({g_type}) - {hours} hours")
        try:
            choice = input(f"\nSelect a goal to remove (1-{len(goals)}) or enter pattern: ").strip()
            if not choice:
                print("Cancelled.")
                conn.close()
                return
            if choice.isdigit() and 1 <= int(choice) <= len(goals):
                pattern = goals[int(choice) - 1]["app_pattern"]
            else:
                pattern = choice
        except (KeyboardInterrupt, EOFError):
            print("\nCancelled.")
            conn.close()
            return
            
    # Verify and delete
    cursor = conn.execute("SELECT COUNT(*) FROM goals WHERE app_pattern = ?;", (pattern,))
    exists = cursor.fetchone()[0] > 0
    if exists:
        conn.execute("DELETE FROM goals WHERE app_pattern = ?;", (pattern,))
        conn.commit()
        print(f"✓ Successfully removed goal for pattern: \033[1;32m{pattern}\033[0m")
        # Trigger daemon restart to re-read goals
        print("Restarting daemon to apply changes...")
        subprocess.run(["systemctl", "--user", "restart", "self-helper.service"], check=False)
    else:
        print(f"\033[1;31mError:\033[0m No goal configuration found for pattern '{pattern}'.")
    conn.close()

