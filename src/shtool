    if not questions_data: print("  No flashcards.")
    else:
        for q in questions_data[:10]: print(f"  • [{q['subject']}] {q['question'][:50]} | Conf: {q['confidence_level']}/5 | Reviews: {q['times_reviewed']}")

    print("\n\033[1;33m[10] Journal Q&A Sessions:\033[0m")
    if not journal_qa_data: print("  No journal sessions.")
    else:
        sessions_shown = set()
        for j in journal_qa_data[:20]:
            if j["session_id"] not in sessions_shown:
                sessions_shown.add(j["session_id"])
                print(f"  --- [{j['journal_type'].upper()}] {j['timestamp'][:16]} ---")
            print(f"    Q: {j['question'][:50]} → A: {j['response_value'][:40]} [{j['time_taken_seconds']:.1f}s]")

    # Save to output file
    out_path = Path.home() / "self_helper_dump.json"
    with open(out_path, "w") as f:
        json.dump(payload, f, indent=2)

    print(f"\n\033[1;32m✓ JSON payload written to: {out_path}\033[0m")
    print("You can provide this JSON file to third-party tools or AI engines for analysis.")

def main() -> None:
    if len(sys.argv) < 2:
        print_help_menu()
        sys.exit(0)

    cmd = sys.argv[1]
    args = sys.argv[2:]

    # Parse and route subcommands
    if cmd in ("--help", "-h", "help"):
        print_help_menu()
    elif cmd == "config":
        if not DB_PATH.exists():
            DB_PATH.parent.mkdir(parents=True, exist_ok=True)
        conn = sqlite3.connect(DB_PATH)
        conn.row_factory = sqlite3.Row
        init_settings(conn)
        
        if len(args) == 0:
            privacy = get_setting(conn, "privacy_level", "low")
            audio = get_setting(conn, "audio_alerts", "on")
            speech = get_setting(conn, "speech_alerts", "off")
            print(f"\033[1;36m=== SHTOOL CONFIGURATION ===\033[0m")
            print(f"Privacy Level: \033[1;32m{privacy.upper()}\033[0m")
            print(f"Audio Alerts (chimes): \033[1;32m{audio.upper()}\033[0m")
            print(f"Speech Alerts (TTS):   \033[1;32m{speech.upper()}\033[0m")
            print("\nConfigure via:")
            print("  \033[1;33mshtool config --privacy [low|medium|high]\033[0m")
            print("  \033[1;33mshtool config --audio [on|off]\033[0m")
            print("  \033[1;33mshtool config --speech [on|off]\033[0m")
        elif len(args) == 2 and args[0] == "--privacy":
            level = args[1].lower()
            if level in ("low", "medium", "high"):
                set_setting(conn, "privacy_level", level)
                print(f"✓ Privacy level updated to: \033[1;32m{level.upper()}\033[0m")
            else:
                print("\033[1;31mError:\033[0m Privacy level must be 'low', 'medium', or 'high'.")
        elif len(args) == 2 and args[0] == "--audio":
            val = args[1].lower()
            if val in ("on", "off"):
                set_setting(conn, "audio_alerts", val)
                print(f"✓ Audio alerts updated to: \033[1;32m{val.upper()}\033[0m")
            else:
                print("\033[1;31mError:\033[0m Audio alerts value must be 'on' or 'off'.")
        elif len(args) == 2 and args[0] == "--speech":
            val = args[1].lower()
            if val in ("on", "off"):
                set_setting(conn, "speech_alerts", val)
                print(f"✓ Speech alerts updated to: \033[1;32m{val.upper()}\033[0m")
            else:
                print("\033[1;31mError:\033[0m Speech alerts value must be 'on' or 'off'.")
        else:
            print("\033[1;31mUsage:\033[0m")
            print("  shtool config")
            print("  shtool config --privacy [low|medium|high]")
            print("  shtool config --audio [on|off]")
            print("  shtool config --speech [on|off]")
        conn.close()
    elif cmd == "status":
        run_command(["/home/vin/.local/bin/self_helper.py", "status"])
    elif cmd == "report":
        run_command(["/home/vin/.local/bin/self_help_report.py"])
    elif cmd == "weekly":
        run_command(["/home/vin/.local/bin/self_help_report.py", "--weekly"])
    elif cmd == "goals":
        run_command(["/home/vin/.local/bin/self_helper.py", "list-goals"])
    elif cmd == "add":
        run_command(["/home/vin/.local/bin/self_helper.py", "add-goal"] + args)
    elif cmd == "remove":
        interactive_remove(args)
    elif cmd == "edit":
        interactive_edit(args)
    elif cmd == "preset":
        apply_preset(args)
    elif cmd == "mood":
        interactive_mood(args)
    elif cmd == "study":
        interactive_study(args)
    elif cmd == "focus":
        run_pomodoro(args)
    elif cmd in ("learning-goal", "lg"):
        manage_learning_goals(args)
    elif cmd == "question":
        manage_questions(args)
    elif cmd == "quiz":
        run_quiz(args)
    elif cmd == "habit":
        manage_habits(args)
    elif cmd == "journal":
        run_guided_journal(args)
    elif cmd in ("quotes", "-quotes", "--quotes"):
        theme_val = None
        for idx, arg in enumerate(args):
            if arg in ("--theme", "-theme", "-the") and idx + 1 < len(args):
                theme_val = args[idx + 1]
                break
        show_quote(theme_val)
    elif cmd == "daemon":
        run_command(["systemctl", "--user", "status", "self-helper.service"])
    elif cmd == "restart":
        run_command(["systemctl", "--user", "restart", "self-helper.service"])
    elif cmd == "dump":
        export_database_dump()
    else:
        print(f"\033[1;31mUnknown command:\033[0m {cmd}")
        print("Type 'shtool --help' to see list of valid commands.")
        sys.exit(1)

if __name__ == "__main__":
    main()
