def manage_learning_goals(args: List[str]) -> None:
    conn = sqlite3.connect(DB_PATH); conn.row_factory = sqlite3.Row; init_settings(conn)
    sub = args[0] if args else "list"
    if sub == "add":
        subj = " ".join(args[1:]) if len(args) > 1 else input("Subject name: ").strip()
        if not subj: print("Cancelled."); conn.close(); return
        conn.execute("INSERT OR IGNORE INTO learning_goals (subject, created_at) VALUES (?, ?);",
                     (subj, datetime.now(timezone.utc).isoformat()))
        conn.commit(); print(f"✓ Learning goal added: \033[1;32m{subj}\033[0m")
    elif sub == "remove":
        cursor = conn.execute("SELECT id, subject FROM learning_goals ORDER BY subject;")
        rows = cursor.fetchall()
        if not rows: print("No learning goals configured."); conn.close(); return
        for i, r in enumerate(rows, 1): print(f"  [{i}] {r['subject']}")
        try:
            c = input(f"Select to remove (1-{len(rows)}): ").strip()
            if c.isdigit() and 1 <= int(c) <= len(rows):
                conn.execute("DELETE FROM learning_goals WHERE id = ?;", (rows[int(c)-1]["id"],))
                conn.commit(); print("✓ Removed.")
        except (KeyboardInterrupt, EOFError): print("\nCancelled.")
    else:
        cursor = conn.execute("SELECT subject, created_at FROM learning_goals ORDER BY subject;")
        rows = cursor.fetchall()
        if not rows: print("No learning goals configured. Use: shtool learning-goal add <subject>")
        else:
            print("\033[1;36m=== LEARNING GOALS ===\033[0m")
            for r in rows: print(f"  • {r['subject']} (added {r['created_at'][:10]})")
    conn.close()

