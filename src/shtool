def run_pomodoro(args: List[str]) -> None:
    import time, sys, subprocess
    try: minutes = int(args[0]) if args else 25
    except ValueError: print("\033[1;31mError:\033[0m Invalid minutes. Usage: shtool focus [minutes]"); return
    
    conn = sqlite3.connect(DB_PATH); conn.row_factory = sqlite3.Row; init_settings(conn)
    limits = [r["app_pattern"] for r in conn.execute("SELECT app_pattern FROM goals WHERE is_limit = 1")]
    
    print(f"\033[1;36m=== 🍅 DEEP WORK FOCUS MODE ({minutes} minutes) ===\033[0m")
    print("Actively enforcing limit goals... Press Ctrl+C to cancel.")
    
    try:
        for remaining in range(minutes * 60, 0, -1):
            sys.stdout.write(f"\r  \033[1;33mTime Remaining:\033[0m {remaining // 60:02d}:{remaining % 60:02d} ")
            sys.stdout.flush()
            if remaining % 5 == 0:
                for limit in limits:
