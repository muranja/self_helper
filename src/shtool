DB_PATH = Path.home() / ".local/share/self_helper/goals_manager.db"

def init_settings(conn: sqlite3.Connection) -> None:
    """Ensures the settings table and default values are initialized."""
    conn.execute("""
        CREATE TABLE IF NOT EXISTS settings (
            key TEXT PRIMARY KEY,
            value TEXT
        );
    """)
    conn.execute("INSERT OR IGNORE INTO settings (key, value) VALUES ('privacy_level', 'low');")
    conn.execute("INSERT OR IGNORE INTO settings (key, value) VALUES ('audio_alerts', 'on');")
    conn.execute("INSERT OR IGNORE INTO settings (key, value) VALUES ('speech_alerts', 'off');")
    conn.commit()

def get_setting(conn: sqlite3.Connection, key: str, default: str) -> str:
    """Retrieves a setting value, falling back to a default."""
    init_settings(conn)
    cursor = conn.execute("SELECT value FROM settings WHERE key = ?", (key,))
    row = cursor.fetchone()
    return row["value"] if row else default

def set_setting(conn: sqlite3.Connection, key: str, value: str) -> None:
    """Persists a setting key-value pair."""
    init_settings(conn)
    conn.execute("INSERT OR REPLACE INTO settings (key, value) VALUES (?, ?)", (key, value))
    conn.commit()

