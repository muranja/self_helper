def apply_preset(args: List[str]) -> None:
    if not args:
        print("\033[1;36mAvailable presets:\033[0m student, nurse, engineer, hobbyist")
        print("Usage: shtool preset <name>")
        return
    name = args[0].lower()
    if name not in PRESETS:
        print(f"\033[1;31mUnknown preset:\033[0m '{name}'. Choose: {', '.join(PRESETS.keys())}")
        return
    preset = PRESETS[name]
    conn = sqlite3.connect(DB_PATH)
    conn.execute("PRAGMA foreign_keys = ON;")
    init_settings(conn)
    now = datetime.now(timezone.utc).isoformat()
    for pattern, hours, is_limit in preset["goals"]:
        conn.execute("INSERT OR IGNORE INTO goals (app_pattern, target_seconds, is_limit, created_at) VALUES (?, ?, ?, ?);",
                     (pattern, int(hours * 3600), 1 if is_limit else 0, now))
    for subj in preset["learning_goals"]:
        conn.execute("INSERT OR IGNORE INTO learning_goals (subject, created_at) VALUES (?, ?);", (subj, now))
    for habit_name, cat in preset["habits"]:
        conn.execute("INSERT OR IGNORE INTO habits (name, category, created_at) VALUES (?, ?, ?);", (habit_name, cat, now))
    conn.commit(); conn.close()
    print(f"✓ Preset '\033[1;32m{name}\033[0m' applied! Goals, learning subjects, and habits configured.")
    subprocess.run(["systemctl", "--user", "restart", "self-helper.service"], check=False)

