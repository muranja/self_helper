    conn.close()

def _get_weather() -> str:
    """Fetches current weather from wttr.in (free, no API key). Returns short string or 'N/A'."""
    import urllib.request
    try:
        req = urllib.request.Request("https://wttr.in/?format=%C+%t", headers={"User-Agent": "SelfHelper/1.0"})
        with urllib.request.urlopen(req, timeout=3.0) as resp:
            return resp.read().decode("utf-8").strip()
    except Exception:
        return "N/A"

def _prompt_scale(prompt: str, low: int = 1, high: int = 10) -> int:
    """Prompts user for a numeric rating within range. Returns the value."""
    while True:
        raw = input(f"{prompt} ({low}-{high}): ").strip()
        if raw.isdigit() and low <= int(raw) <= high:
            return int(raw)
        print(f"  Please enter a number between {low} and {high}.")

def interactive_mood(args: List[str]) -> None:
    import time
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    init_settings(conn)

    if len(args) > 0 and args[0] == "journal":
        cursor = conn.execute(
            "SELECT timestamp, mood_score, energy_score, focus_score, mood_label, factors, gratitude, notes, weather_info "
            "FROM mood_journal ORDER BY timestamp DESC LIMIT 20;")
        rows = cursor.fetchall()
        if not rows:
            print("\033[1;33mMood journal is empty. Use 'shtool mood' to log your first entry!\033[0m")
        else:
            print("\033[1;36m=== MOOD JOURNAL HISTORY ===\033[0m")
