def manage_habits(args: List[str]) -> None:
    conn = sqlite3.connect(DB_PATH); conn.row_factory = sqlite3.Row; init_settings(conn)
    sub = args[0] if args else "list"
    today = datetime.now().strftime("%Y-%m-%d")
    if sub == "add":
        name = " ".join(args[1:]) if len(args) > 1 else input("Habit name: ").strip()
        cat = input("Category (general/health/academic/professional/creative): ").strip() or "general"
        if not name: print("Cancelled."); conn.close(); return
        conn.execute("INSERT OR IGNORE INTO habits (name, category, created_at) VALUES (?, ?, ?);",
                     (name, cat, datetime.now(timezone.utc).isoformat()))
        conn.commit(); print(f"✓ Habit added: \033[1;32m{name}\033[0m")
    elif sub == "remove":
        cursor = conn.execute("SELECT id, name FROM habits ORDER BY name;"); rows = cursor.fetchall()
        if not rows: print("No habits configured."); conn.close(); return
        for i, r in enumerate(rows, 1): print(f"  [{i}] {r['name']}")
        try:
            c = input(f"Remove (1-{len(rows)}): ").strip()
            if c.isdigit() and 1 <= int(c) <= len(rows):
                conn.execute("DELETE FROM habits WHERE id = ?;", (rows[int(c)-1]["id"],))
                conn.commit(); print("✓ Removed.")
        except (KeyboardInterrupt, EOFError): print("\nCancelled.")
    elif sub == "track":
        cursor = conn.execute("SELECT id, name FROM habits ORDER BY name;"); habits = cursor.fetchall()
        if not habits: print("No habits to track. Use: shtool habit add"); conn.close(); return
        print(f"\033[1;36m=== DAILY HABIT TRACKER ({today}) ===\033[0m")
        for h in habits:
            log = conn.execute("SELECT status FROM habit_logs WHERE habit_id = ? AND date = ?;", (h["id"], today)).fetchone()
            done = log["status"] if log else 0
            mark = "✓" if done else "✗"
            color = "\033[1;32m" if done else "\033[1;31m"
            print(f"  {color}[{mark}]\033[0m {h['name']}")
        try:
            toggle = input("\nEnter habit number to toggle (or 'done'): ").strip()
            while toggle.lower() != "done" and toggle:
                if toggle.isdigit() and 1 <= int(toggle) <= len(habits):
                    hid = habits[int(toggle)-1]["id"]
                    old = conn.execute("SELECT status FROM habit_logs WHERE habit_id = ? AND date = ?;", (hid, today)).fetchone()
                    new_status = 0 if (old and old["status"]) else 1
                    conn.execute("INSERT OR REPLACE INTO habit_logs (habit_id, date, status) VALUES (?, ?, ?);", (hid, today, new_status))
                    conn.commit()
                    st = "✓ Done" if new_status else "✗ Undone"
                    print(f"  {habits[int(toggle)-1]['name']} → {st}")
                toggle = input("Toggle another (or 'done'): ").strip()
        except (KeyboardInterrupt, EOFError): pass
        print("✓ Habit tracking updated!")
    else:
        cursor = conn.execute("SELECT id, name, category FROM habits ORDER BY category, name;"); rows = cursor.fetchall()
        if not rows: print("No habits yet. Use: shtool habit add")
        else:
            print("\033[1;36m=== CONFIGURED HABITS ===\033[0m")
            for r in rows: print(f"  • [{r['category']}] {r['name']}")
    conn.close()

