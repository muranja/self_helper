def run_quiz(args: List[str]) -> None:
    import time
    from datetime import timedelta
    conn = sqlite3.connect(DB_PATH); conn.row_factory = sqlite3.Row; init_settings(conn)
    now = datetime.now(timezone.utc)
    now_iso = now.isoformat()
    
    cursor = conn.execute("SELECT id, subject, question, answer, confidence_level, ease_factor, interval, times_reviewed FROM questions_catalog WHERE next_review_date IS NULL OR next_review_date <= ? ORDER BY RANDOM() LIMIT 10;", (now_iso,))
    cards = cursor.fetchall()
    if not cards: print("No flashcards due for review right now! Use: shtool question add"); conn.close(); return
    
    print(f"\033[1;36m=== SELF-TEST QUIZ ({len(cards)} questions due) ===\033[0m\n")
    for idx, card in enumerate(cards, 1):
        print(f"\033[1;33mQ{idx}.\033[0m [{card['subject']}] {card['question']}")
        t0 = time.time()
        try: input("  Press Enter to reveal answer...")
        except (KeyboardInterrupt, EOFError): print("\nQuiz ended early."); conn.close(); return
        elapsed = round(time.time() - t0, 1)
        print(f"  \033[1;32mAnswer:\033[0m {card['answer'] or '(no answer stored)'}")
        new_conf = _prompt_scale("  Rate your confidence now", 1, 5)
        
        # SuperMemo-2 Algorithm
        q = new_conf
        ef = card["ease_factor"] if card["ease_factor"] is not None else 2.5
        interval = card["interval"] if card["interval"] is not None else 0
        reps = card["times_reviewed"] if card["times_reviewed"] is not None else 0
        
        if q >= 3:
            if reps == 0: interval = 1
            elif reps == 1: interval = 6
            else: interval = max(1, round(interval * ef))
            reps += 1
        else:
            reps = 0
            interval = 1
            
        ef = ef + (0.1 - (5 - q) * (0.08 + (5 - q) * 0.02))
        if ef < 1.3: ef = 1.3
        
        next_review_iso = (now + timedelta(days=interval)).isoformat()
        
        conn.execute("UPDATE questions_catalog SET confidence_level = ?, times_reviewed = ?, last_reviewed = ?, ease_factor = ?, interval = ?, next_review_date = ? WHERE id = ?;",
                     (new_conf, reps, now_iso, ef, interval, next_review_iso, card["id"]))
        conn.commit()
        print(f"  (Took {elapsed}s. Next review in {interval} day(s))\n")
    print("✓ Quiz session complete!"); conn.close()

